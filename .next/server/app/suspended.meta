{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/suspended/layout,_N_T_/suspended/page,_N_T_/suspended"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/suspended/__PAGE__",
    "/suspended",
    "/_index",
    "/_head"
  ]
}