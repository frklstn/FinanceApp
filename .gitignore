# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Node.js / Next.js ───────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# ─── Environment & Secrets ───────────────────────────────────────────────
.env*
!.env.example
*.pem
*.jks
*.keystore
key.properties

# ─── Vercel ──────────────────────────────────────────────────────────────
.vercel

# ─── TypeScript ──────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Flutter / Mobile ────────────────────────────────────────────────────
mobile/build/
mobile/.dart_tool/
mobile/.idea/
mobile/.pub-cache/
mobile/.pub/
mobile/.flutter-plugins-dependencies
mobile/*.iml
mobile/android/.gradle/
mobile/android/.kotlin/
mobile/android/local.properties
mobile/android/*.iml
mobile/android/app/debug/
mobile/android/app/profile/
mobile/android/app/release/

# ─── OS Files ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE ─────────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.swp
*.swo

# ─── Debug Logs ──────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ─── Firebase (if added later) ───────────────────────────────────────────
google-services.json
GoogleService-Info.plist
firebase_options.dart
